#: ../../hardware/controllers/pioneer_ddj_sb3.md:275
msgid "Pad Scratch Mode"
msgstr ""

#: ../../hardware/controllers/pioneer_ddj_sb3.md:277
msgid ""
"Pad scratch mode is enabled by pressing the {hwlabel}`PAD SCRATCH` button. "
"The button will light up when selected. Press one of the pads to trigger one"
" of the built in scratches."
msgstr ""

