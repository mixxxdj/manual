#: ../../hardware/controllers/pioneer_ddj_sb.md:1
msgid "Pioneer DDJ-SB"
msgstr ""

#: ../../hardware/controllers/pioneer_ddj_sb.md:4
msgid ""
"The Pioneer DDJ-SB is an all-in-one 2 deck USB {term}`MIDI` controller with "
"a built in soundcard. Mixxx allows it to control 4 decks."
msgstr ""

#: ../../hardware/controllers/pioneer_ddj_sb.md:6
msgid ""
"[Manufacturer’s product "
"page](https://www.pioneerdj.com/en/product/controller/archive/ddj-"
"sb/black/overview/)"
msgstr ""

#: ../../hardware/controllers/pioneer_ddj_sb.md:7
msgid ""
"[Forum thread](https://mixxx.discourse.group/t/midi-mapping-for-pioneer-ddj-"
"sb/14806)"
msgstr ""

