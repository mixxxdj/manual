msgid "8"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "{hwlabel}`BASS`"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "Adjust low frequencies"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "9"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "{hwlabel}`Channel fader`"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "Adjust volume level"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "11"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "{hwlabel}`CUE`"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid ""
"{term}`Headphone button`. Toggle sending channel to the cue (headphone) "
"channel"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "12"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "{hwlabel}`Jog wheel`"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid ""
"If scratch mode is enabled (see the {hwlabel}`SCRATCH` button below): "
"scratch<br><br>If scratch mode is disabled: pitch bend<br><br>The behavior "
"of the jog wheel can be fine-tuned, see the {ref}`Adjustable "
"values<numark_party_mix_adjustable>` section."
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "13"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "{hwlabel}`SCRATCH`"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "Toggle scratch mode. Disabled by default."
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "14"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "{hwlabel}`Pitch fader`"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "Adjust the speed of the track"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "15"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "{hwlabel}`SYNC`"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid ""
"If sync lock is disabled: set BPM to the other deck's BPM<br><br>If sync "
"lock is enabled: disable sync lock"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "{hwlabel}`SYNC` (hold, then release)"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "Enable {term}`sync lock`"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "16"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid ""
"If track is playing: stops the track and resets position to the main cue "
"point<br><br>If playback is stopped: sets the main cue point"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "{hwlabel}`CUE` (hold)"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid ""
"Play the track from main cue point, release to stop playback and return to "
"the main cue point. Playback must be initially stopped on the main cue "
"point."
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "17"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "{hwlabel}`Play/Pause`"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "Play/pause playback"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
#: ../../hardware/controllers/numark_party_mix.md:60
msgid "18"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "{hwlabel}`PADS 1-4`"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "Pads 1-4 function depends on selected mode"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "19"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "{hwlabel}`PAD MODE`"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "Select mode of {hwlabel}`PADS 1-4`"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "20"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "{hwlabel}`MODE LEDs`"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid ""
"The 4 pads in each deck have multiple functions, depending on the selected "
"*pad mode*. Default pad mode is *hotcues*. Current mode is selected by "
"pressing {hwlabel}`PAD MODE`. The LED for currently active pad mode is lit "
"up (or all 3 LEDs for effect mode)."
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:61
msgid ""
"The actual behavior of CUE and Play/Pause buttons depends on Mixxx settings."
" See {ref}`interface-cue-modes` for more info."
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:64
msgid "Pads"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:60
msgid "{hwlabel}`CUE Mode`"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:60
msgid ""
"set hotcue if not set. If set, go to hotcue position and start "
"playback.<br><br>Pad lights indicate if a particular hotcue is set or not."
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:60
msgid "{hwlabel}`LOOP Mode`"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:60
msgid ""
"activate auto-loop.<br><br>Default auto-loop sizes are: 4, 8, 16, 32. Loop "
"sizes can be adjusted, see the {ref}`Adjustable "
"values<numark_party_mix_adjustable>` section."
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:60
msgid "{hwlabel}`SAMPLER Mode`"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:60
msgid ""
"button for 4 Samples for each Deck 1-4 and 5-8 (toggle play from start and "
"stop)."
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:60
msgid "{hwlabel}`EFFECT Mode`"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:60
msgid ""
"Pad 1-3 activates effect during press Deck1 of EffectUnit1, Deck2 of "
"EffectUnit2.<br><br>Pad 4 switches mix mode. Pad light on indicates Dry/Wet "
"mode. Pad Light off indicates Dry+Wet mode."
msgstr ""

