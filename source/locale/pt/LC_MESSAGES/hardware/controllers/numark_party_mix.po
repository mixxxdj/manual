msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "{hwlabel}`CUE MIX`"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid ""
"{term}`Head/mix knob<Head/mix button>`. Adjust the cue/main mix in the "
"headphone output."
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "5"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "{hwlabel}`CUE GAIN`"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "Adjust the headphone volume"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "10"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid "{hwlabel}`Crossfader`"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:14
msgid ""
"Controls the mix between the two decks. See {ref}`interface-crossfader`"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:35
msgid "Deck"
msgstr ""

#: ../../hardware/controllers/numark_party_mix.md:38
msgid ""
"Each of those controls exists in both {term}`decks<deck>` and affects only "
"the corresponding deck."
msgstr ""

