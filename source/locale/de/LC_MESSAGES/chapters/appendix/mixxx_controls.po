#: ../../chapters/appendix/mixxx_controls.rst:72
msgid "``_up``"
msgstr ""

#: ../../chapters/appendix/mixxx_controls.rst:72
msgid ""
"Increases the value, e.g. :mixxx:coref:`[ChannelN],rate_perm_up` sets the "
"speed one step higher (4 % default)"
msgstr ""

#: ../../chapters/appendix/mixxx_controls.rst:73
msgid "``_down``"
msgstr ""

#: ../../chapters/appendix/mixxx_controls.rst:73
msgid "Decreases the value, sets the speed one step lower (4 % default)"
msgstr ""

#: ../../chapters/appendix/mixxx_controls.rst:74
msgid "``_up_small``"
msgstr ""

#: ../../chapters/appendix/mixxx_controls.rst:74
msgid ""
"Increases the value by smaller step, sets the speed one small step higher (1"
" % default)"
msgstr ""

#: ../../chapters/appendix/mixxx_controls.rst:75
msgid "``_down_small``"
msgstr ""

#: ../../chapters/appendix/mixxx_controls.rst:75
msgid ""
"Decreases the value by smaller step, sets the speed one small step lower (1 "
"% default)"
msgstr ""

#: ../../chapters/appendix/mixxx_controls.rst:76
msgid "``_set_one``"
msgstr ""

#: ../../chapters/appendix/mixxx_controls.rst:76
msgid "Sets the value to 1.0, sets the channel volume to full"
msgstr ""

#: ../../chapters/appendix/mixxx_controls.rst:77
msgid "``_set_minus_one``"
msgstr ""

#: ../../chapters/appendix/mixxx_controls.rst:77
msgid "Sets the value to -1.0, sets the channel volume to zero"
msgstr ""

#: ../../chapters/appendix/mixxx_controls.rst:78
#: ../../chapters/appendix/mixxx_controls.rst:79
msgid "``_set_default``"
msgstr ""

#: ../../chapters/appendix/mixxx_controls.rst:78
msgid ""
"Input: sets the control to its default, return to default waveform zoom "
"level"
msgstr ""

#: ../../chapters/appendix/mixxx_controls.rst:79
msgid ""
"Output: set to 1.0 if the control is at its default, light up the pitch "
"fader center indicator"
msgstr ""

#: ../../chapters/appendix/mixxx_controls.rst:80
msgid "``_set_zero``"
msgstr ""

#: ../../chapters/appendix/mixxx_controls.rst:80
msgid "Sets the value to 0.0, put the crossfader in the middle again"
msgstr ""

#: ../../chapters/appendix/mixxx_controls.rst:81
msgid "``_toggle``"
msgstr ""

#: ../../chapters/appendix/mixxx_controls.rst:81
msgid ""
"Sets the value to 0.0 if the value was > 0.0, and to 1.0 if the value was "
"0.0, will cut off/on a track while you're playing"
msgstr ""

#: ../../chapters/appendix/mixxx_controls.rst:82
msgid "``_minus_toggle``"
msgstr ""

#: ../../chapters/appendix/mixxx_controls.rst:82
msgid ""
"Sets the value to -1.0 if the value was > -1.0, and to 1.0 if the value was "
"-1.0, can tilt the crossfader from left to right"
msgstr ""

