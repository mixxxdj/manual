msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid ""
"Press one of these buttons while a track is selected to assign it to Deck 1 "
"or 2, respectively."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "{hwlabel}`2X Press` Track Cloning"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid ""
"Quickly double press a Load button to clone the track of the adjacent deck."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "{hwlabel}`SHIFT` Eject"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
