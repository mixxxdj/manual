msgid "8"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Level"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid ""
"Adjusts the pre-fader, pre-EQ audio level of the corresponding channel."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "9"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "High EQ"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Controls the treble frequencies for the individual channels"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "10"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Mid EQ"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Controls the mid-range frequencies for the individual channels."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "11"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Low EQ"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Controls the bass frequencies for the individual channels."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "12"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Filter"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid ""
"Adjusts the amount of the filter effect. Turning the knob left and right "
"will produce a lowpass filter and high-pass filter, respectively."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "13"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Cue/PFL"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Sends pre-fader audio to the cue channel for headphone monitoring."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "{hwlabel}`SHIFT` Slip Mode"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Toggles slip mode on/off for related deck."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "14"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Channel Fader"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Adjusts the volume of the individual channels in the software."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "15"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Crossfader"
msgstr "Crossfader"

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Controls the blend between the two decks"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "16"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Pitch Bend Down"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Press and hold to momentarily reduce the speed of the track."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "{hwlabel}`SHIFT` Pitch Range"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Hold Shift and this button to adjust Pitch Range"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "17"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Pitch Bend Up"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "{hwlabel}`SHIFT` Keylock"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Hold Shift and this button to adjust Keylock."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "18"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Pitch Fader"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid ""
"This controls the speed of the music. Moving towards the + will speed the "
"music up, while moving towards the – will slow it down."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "19"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Beats Multiplier"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid ""
"Increases and decreases the rate of the effects to the beat. When using a "
"time-based effect, this knob adjusts its time division."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "{hwlabel}`SHIFT` FX Macros"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Selects and controls FX Macros parameters."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "20"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "FX Wet/Dry Knob"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Turn this knob to adjust the wet/dry mix of the effects."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "21"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Software FX"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid ""
"Press one of these buttons to select the user assigned software effect.<br>•"
" HPF (High pass filter)<br>• LPF (Low pass filter)<br>• Flanger<br>• "
"Echo<br>• Reverb<br>• Phaser<br>FX Buttons will need to be assigned with "
"mixxx [Effects](https://manual.mixxx.org/2.5/en/chapters/effects#effects) "
"selectors in the graphical interface."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "{hwlabel}`SHIFT` Multiple FX (at once)"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid ""
"Hold shift and select/unselect multiple FX buttons to be active at once."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "22"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "FX Toggle On / Off:"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid ""
"Push up on the toggle switch to latch (lock) the FX in the on position. Push"
" down on the toggle switch to turn the FX on momentarily. When the toggle "
"switch is in the middle position, the FX will be off."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "23"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Tap BPM"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid ""
"Press this a minimum of 4 times to manually enter a new BPM. The software "
"will ignore the track's BPM and follow your manually entered tempo.<br>See "
"{ref}`Tapping Logic <numark-platinum-fx-tapping-logic>`"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Left {hwlabel}`PFL` ON (Right off)"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid ""
"Set BPM for left deck.<br>See {ref}`Tapping Logic <numark-platinum-fx-"
"tapping-logic>`"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Right {hwlabel}`PFL` ON (Left off)"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid ""
"Set BPM for right deck.<br>See {ref}`Tapping Logic <numark-platinum-fx-"
"tapping-logic>`"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "{hwlabel}`SHIFT` Default Tempo Reset"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid ""
"Press Shift and this button to reset the tempo to the track to default "
"BPM.<br>Note: Reset the selected deck. See {ref}`Tapping Logic <numark-"
"platinum-fx-tapping-logic>`"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "24"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Platter/Jog Wheel"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid ""
"This capacitive, touch-sensitive jog wheel controls the audio when the wheel"
" is touched and moved. When the Scratch button is not active, use the jog "
"wheel to bend the pitch of the track. When the Scratch button is active, use"
" the jog wheel to grab and move the audio, scratching the track as you would"
" with a vinyl record. You can also grab the non-touch-sensitive outer wheel,"
" to bend the pitch of the track."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "{hwlabel}`SHIFT` Scrub Scroll"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Scrub Scrolling while holding Jog wheel."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "25"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Deck Display"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid ""
"**1. Active Deck:** Indicates the currently active deck.<br>**2. Platter "
"Position:** Displays the current track position.<br>**3. BPM:** Displays the"
" current BPM for the selected track.<br>**4. Keylock:** This icon "
"illuminates when keylock is active for the current deck.<br>**5. Pitch "
"Range:** Shows the current pitch range.<br>**6. Pitch:** Shows current pitch"
" of the track.<br>**7. Pitch Adjust:** Indicates the direction to move Pitch"
" Fader to match the current track's BPM with the track on the opposite "
"deck.<br>**8. Time Remaining:** Displays the time elapsed or time remaining "
"for the current track. (Time elapsed only implemented in current "
"mapping).<br>**9. Time Bars:** Provides visual reference to time remaining "
"on the selected song. When the song is almost over these segments will flash"
" to give a warning."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "26"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Scratch"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Press this button to turn on the scratch feature for the jog wheel."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "{hwlabel}`SHIFT` Deck Select"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Switch between decks 1 & 3 or 2 & 4 for 4 deck mixing"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "27"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Shift"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid ""
"Allows multiple control commands to be triggered when pressed first along "
"with other buttons."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "28"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Sync (tap)"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid ""
"Automatically match the corresponding Deck's tempo with the opposite Deck's "
"tempo."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Lock Sync (hold)"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid ""
"Hold for at least one second to lock sync. Tap again to release sync lock."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "{hwlabel}`SHIFT` Quantize"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Toggle quantize on/off."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "29"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Cue (tap)"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Sets and recalls the main Cue point in the current track"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Cue Play (hold)"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid ""
"Play from the Cue point for as long as the button is held down and return to"
" the cue point once it is released"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "{hwlabel}`SHIFT` Cue Track Start"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Return cue head to beginning of track."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "30"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Play/Pause"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Starts and suspends playback."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "{hwlabel}`SHIFT` Beat Grid Adjust"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid ""
"Adjust Beat Grid, Hold shift and this button to align closest beat to the "
"current play position."
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "31"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Cue (Pad)"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid ""
"With this Pad mode, each pad assigns a Hot Cue Point, or returns the track "
"to that Hot Cue Point. When a pad is unlit, you can assign a Hot Cue Point "
"by pressing it at the desired point in your track.<br>See {ref}`Performance "
"Pad Modes <numark-platinum-fx-performance-pad-modes>`"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "{hwlabel}`SHIFT` Secondary Hot Cue"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Hot Cue 9-16"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "{hwlabel}`HOLD` or {hwlabel}`2X PRESS`<br>Beat Jump"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "Beat Jump"
msgstr ""

#: ../../hardware/controllers/numark_mixtrack_platinum_fx.md:40
msgid "32"
