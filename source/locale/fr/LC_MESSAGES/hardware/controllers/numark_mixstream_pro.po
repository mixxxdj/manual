msgid "Move this fader to adjust the speed (pitch) of the track."
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:134
msgid "27"
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:134
msgid "Pitch Bend –/+"
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:0
msgid ""
"Press and hold one of these buttons to momentarily reduce or increase "
"(respectively) the speed of the track."
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:0
msgid ":hwlabel:`SHIFT` + **Press:** set the range of the pitch fader."
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:136
msgid "28"
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:136
msgid "Performance Pads"
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:0
msgid ""
"These pads have different functions on each deck depending on the current "
"pad mode. See Pad Modes for more information."
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:137
msgid "29"
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:137
msgid "Cue"
msgstr "Repère"

#: ../../hardware/controllers/numark_mixstream_pro.rst:0
msgid ""
"Press this button to enter Cue mode. Press the button again to enter a "
"second bank of cues. To assign a cue to a pad, press a pad at the desired "
"location in the track."
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:0
msgid ":hwlabel:`SHIFT` + **Pad:** clear a cue from a pad."
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:0
msgid ":hwlabel:`SHIFT` + **Cue:** enter Stems Mode."
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:140
msgid "30"
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:140
msgid "Saved Loop"
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:0
msgid ""
"Press this button to enter Saved Loop mode. Press the button again to enter "
"a second bank of saved loops."
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:0
msgid ""
"To assign a loop to a pad and activate it, press a pad to create a Loop In "
"point at the current location, and then press it again to create the Loop "
"Out point at another location."
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:0
msgid "To deactivate or reactivate a loop, press the corresponding pad."
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:0
msgid ":hwlabel:`SHIFT` + **Pad:** delete a loop from a pad."
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:144
msgid "31"
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:144
msgid "Auto Loop"
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:0
msgid ""
"Press this button to enter Auto Loop mode. Press the button again to enter a"
" second bank of auto loop lengths."
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:0
msgid ""
"To activate an auto loop, press a pad. To deactivate an auto loop, press the"
" pad again."
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:146
msgid "32"
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:146
msgid "Roll"
msgstr ""

#: ../../hardware/controllers/numark_mixstream_pro.rst:0
msgid ""
"Press this button to enter Roll Mode. Press the button again to enter a "
"second bank of roll lengths. To trigger a roll, press a pad."
msgstr ""

