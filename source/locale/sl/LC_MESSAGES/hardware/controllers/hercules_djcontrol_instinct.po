#: ../../hardware/controllers/hercules_djcontrol_instinct.md:73
msgid "**2:** Play Sample 2"
msgstr ""

#: ../../hardware/controllers/hercules_djcontrol_instinct.md:74
msgid "**3:** Play Sample 3"
msgstr ""

