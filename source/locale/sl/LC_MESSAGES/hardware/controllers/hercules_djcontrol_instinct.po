msgid "Hercules DJControl Instinct (schematic view)"
msgstr ""

#: ../../hardware/controllers/hercules_djcontrol_instinct.md:43
msgid ""
"Hercules DJControl Instinct (schematic view). This picture is taken from the"
" product poster in the device manual (courtesy of Guillemot Corporation "
"S.A.)."
msgstr ""

