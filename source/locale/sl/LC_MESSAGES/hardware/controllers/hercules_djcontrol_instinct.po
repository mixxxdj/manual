#: ../../hardware/controllers/hercules_djcontrol_instinct.md:52
msgid "**2:** Set and play (by holding it) from Hot Cue 2"
msgstr ""

#: ../../hardware/controllers/hercules_djcontrol_instinct.md:53
msgid "**3:** Reset Hot Cue 1"
msgstr ""

#: ../../hardware/controllers/hercules_djcontrol_instinct.md:54
msgid "**4:** Reset Hot Cue 2"
msgstr ""

#: ../../hardware/controllers/hercules_djcontrol_instinct.md:56
msgid "Loop"
msgstr ""

#: ../../hardware/controllers/hercules_djcontrol_instinct.md:58
msgid "**1:** Set Loop start"
msgstr ""

#: ../../hardware/controllers/hercules_djcontrol_instinct.md:59
msgid "**2:** Set loop end"
msgstr ""

#: ../../hardware/controllers/hercules_djcontrol_instinct.md:60
msgid "**3:** Shrink loop (halves it)"
msgstr ""

#: ../../hardware/controllers/hercules_djcontrol_instinct.md:61
msgid "**4:** Exit loop"
msgstr ""

